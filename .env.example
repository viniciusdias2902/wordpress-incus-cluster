# Copie para .env e ajuste os valores antes de subir o stack:
#   cp .env.example .env

# Banco de dados (MariaDB)
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=troque_esta_senha

# Porta exposta pelo load balancer (nginx) no host.
# Use 8080 se já houver um nginx/Apache do host na 80 (recomendado na VPS,
# onde o nginx do host faz o TLS de viniciusdias.tech e repassa pra cá).
LB_PORT=8080

# URL pública do site. Local: http://localhost:8080
# Na VPS, sob subpath: https://viniciusdias.tech/loja
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
